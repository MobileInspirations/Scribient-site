{
  "kind": "collectionType",
  "collectionName": "authors",
  "info": {
    "singularName": "author",
    "pluralName": "authors",
    "displayName": "Author"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "headshot": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "role": {
      "type": "string"
    },
    "bio": {
      "type": "text"
    },
    "socialLinks": {
      "type": "component",
      "repeatable": true,
      "component": "navigation.link"
    }
  }
}
